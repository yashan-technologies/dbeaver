<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>
    <extension point="org.jkiss.dbeaver.databaseEditor">
        <editor
            id="org.jkiss.dbeaver.ext.cubrid.ui.editors.CubridPrivilageEditor"
            class="org.jkiss.dbeaver.ext.cubrid.ui.editors.CubridPrivilageEditor"
            objectType="org.jkiss.dbeaver.ext.cubrid.model.CubridPrivilage"
            main="true"
            label="%editor.general.name"
            description="General user settings"
            icon="#user">
        </editor>
        <configurator class="org.jkiss.dbeaver.ext.cubrid.ui.config.CubridTableUniqueKeyConfigurator">
            <objectType name="org.jkiss.dbeaver.ext.cubrid.model.CubridUniqueKey"/>
        </configurator>
        <configurator class="org.jkiss.dbeaver.ext.cubrid.ui.config.CubridTableColumnConfigurator">
            <objectType name="org.jkiss.dbeaver.ext.cubrid.model.CubridTableColumn"/>
        </configurator>
        <configurator class="org.jkiss.dbeaver.ext.cubrid.ui.config.CubridProcedureConfigurator">
            <objectType name="org.jkiss.dbeaver.ext.cubrid.model.CubridProcedure"/>
        </configurator>
    </extension>

    <extension point="org.jkiss.dbeaver.dataSourceView">
        <view
            id="org.jkiss.dbeaver.ext.cubrid.dataSourceWizardView"
            class="org.jkiss.dbeaver.ext.cubrid.ui.views.CubridConnectionPage"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.cubrid/icons/cubrid_icon.png"
            dataSource="cubrid"
            label="%dialog.connection.header"
            targetID="org.jkiss.dbeaver.ext.ui.newConnectionWizard">
        </view>
        <view
            id="org.jkiss.dbeaver.ext.cubrid.dataSourceEditorView"
            class="org.jkiss.dbeaver.ext.cubrid.ui.views.CubridConnectionPage"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.cubrid/icons/cubrid_icon.png"
            dataSource="cubrid"
            label="%dialog.connection.header"
            targetID="org.jkiss.dbeaver.ext.ui.editConnectionDialog">
        </view>
    </extension>

    <extension point="org.eclipse.ui.preferencePages">
        <page category="org.jkiss.dbeaver.preferences.drivers" id="org.jkiss.dbeaver.preferences.cubrid.general" class="org.jkiss.dbeaver.ext.cubrid.ui.views.PrefPageCubrid" name="%views.PrefPageCubrid.name">
            <keywordReference id="org.jkiss.dbeaver.core.keyword.dbeaver"/>
        </page>
    </extension>

    <extension point="org.jkiss.dbeaver.resultset.panel">
         <panel
                id="cubridResult"
                label="%controls.CubridInfoPanel.label"
                description="%controls.CubridInfoPanel.description"
                icon="platform:/plugin/org.jkiss.dbeaver.model/icons/tree/table.svg"
                default="true"
                class="org.jkiss.dbeaver.ext.cubrid.ui.controls.CubridInfoPanel">
             <datasource id="cubrid"/>
        </panel>
    </extension>

    <extension point="org.jkiss.dbeaver.sql.plan.view">
        <view id="fulltext"
              priority="101"
              label="%sql.plan.view.fulltext.name"
              icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/sql/page_explain_plan.svg"
              description="%sql.plan.view.fulltext.tip"
              class="org.jkiss.dbeaver.ext.cubrid.ui.editors.CubridSQLPlanViewProvider">
            <datasource id="cubrid"/>
        </view>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <command id="org.jkiss.dbeaver.cubrid.OIDNavigator" name="%views.CubridOIDSearchDiaglog.name" description="views.CubridOIDSearchDiaglog.description" categoryId="org.jkiss.dbeaver.core.navigator"/>
    </extension>

    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.dbeaver.cubrid.OIDNavigator" icon="platform:/plugin/org.jkiss.dbeaver.ext.cubrid/icons/cubrid_icon.png"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.dbeaver.cubrid.OIDNavigator" class="org.jkiss.dbeaver.ext.cubrid.ui.config.CubridOIDHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="+"/>
                    <iterate operator="and">
                        <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                            <instanceof value="org.jkiss.dbeaver.ext.cubrid.model.CubridDataSource"/>
                        </adapt>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=object">
            <command commandId="org.jkiss.dbeaver.cubrid.OIDNavigator">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
    </extension>
</plugin>
