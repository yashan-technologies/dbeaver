<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.dbeaver.dataSourceProvider">

        <!-- BigQuery -->

        <datasource
                class="org.jkiss.dbeaver.ext.bigquery.BQDataSourceProvider"
                description="%datasource.bq.description"
                id="bigquery"
                parent="generic"
                label="Google BigQuery"
                icon="icons/bigquery_icon.png"
                dialect="google_bigquery">
            <drivers managable="true">

                <!-- Simba JDBC driver -->
                <driver
                        id="google_bigquery_jdbc_simba"
                        label="Google BigQuery"
                        icon="icons/bigquery_icon.png"
                        iconBig="icons/bigquery_icon_big.png"
                        class="com.simba.googlebigquery.jdbc42.Driver"
                        sampleURL="jdbc:bigquery://{host}:{port}"
                        defaultHost="https://www.googleapis.com/bigquery/v2"
                        defaultPort="443"
                        description="Legacy Google BigQuery driver (Simba)"
                        webURL="https://docs.cloud.google.com/bigquery/docs/reference/odbc-jdbc-drivers"
                        propertiesURL="https://cdn.simba.com/products/BigQuery/doc/JDBC_InstallGuide/"
                        databaseDocumentationSuffixURL="Database-driver-BigQuery"
                        categories="sql,gcp"
                        singleConnection="true">
                    <file type="jar" path="https://storage.googleapis.com/simba-bq-release/jdbc/SimbaJDBCDriverforGoogleBigQuery42_1.6.5.1002.zip" bundle="!drivers.bigquery"/>
                    <file type="license" path="licenses/external/lgpl-3.0.txt"/>

                    <file type="jar" path="drivers/bigquery" bundle="drivers.bigquery"/>
                    <file type="jar" path="bundle:/org.jkiss.bundle.google-cloud" bundle="drivers.bigquery"/>
                    <file type="license" path="drivers/bigquery/EULA.txt" bundle="drivers.bigquery"/>

                    <property name="@dbeaver-default-resultset.maxrows.sql" value="true"/>
                    <parameter name="supports-catalog-selection" value="false"/>
                    <parameter name="supports-ddl-transactions" value="false"/>
                    <parameter name="supports-schema-selection" value="false"/>
                </driver>

                <!-- Google JDBC driver -->
                <driver
                    id="google_bigquery_jdbc"
                    label="Google BigQuery (Experimental)"
                    icon="icons/bigquery_icon.png"
                    iconBig="icons/bigquery_icon_big.png"
                    class="com.google.cloud.bigquery.jdbc.BigQueryDriver"
                    sampleURL="jdbc:bigquery://{host}:{port}"
                    defaultHost="https://www.googleapis.com/bigquery/v2"
                    defaultPort="443"
                    description="Google BigQuery driver"
                    webURL="https://docs.cloud.google.com/bigquery/docs/jdbc-for-bigquery"
                    databaseDocumentationSuffixURL="Database-driver-BigQuery"
                    categories="sql,gcp"
                    singleConnection="true"
                    propagateDriverProperties="true">
                    <file type="jar" path="maven:/com.google.cloud:google-cloud-bigquery-jdbc:RELEASE[0.6.0]" bundle="!drivers.google-bigquery"/>

                    <file type="jar" path="drivers/google-bigquery" bundle="drivers.google-bigquery"/>
                    <file type="jar" path="bundle:/org.jkiss.bundle.google-cloud" bundle="drivers.google-bigquery"/>
                    <file type="license" path="drivers/google-bigquery/EULA.txt" bundle="drivers.google-bigquery"/>

                    <property name="@dbeaver-default-resultset.maxrows.sql" value="true"/>
                    <parameter name="supports-catalog-selection" value="false"/>
                    <parameter name="supports-ddl-transactions" value="false"/>
                    <parameter name="supports-schema-selection" value="false"/>
                </driver>

                <provider-properties drivers="*">
                    <propertyGroup label="Settings">
                        <property id="AdditionalProjects" label="Additional project(s)" type="string" description="Comma-separated list of projects (optional)"/>
                    </propertyGroup>
                </provider-properties>
            </drivers>

        </datasource>
    </extension>

    <extension point="org.jkiss.dbeaver.sqlDialect">
        <dialect id="google_bigquery" parent="generic" class="org.jkiss.dbeaver.ext.bigquery.model.BQSQLDialect" label="BigQuery" description="Google BigQuery." icon="icons/bigquery_icon.png">
        </dialect>
    </extension>

    <extension point="org.jkiss.dbeaver.generic.meta">
        <meta id="bigquery" class="org.jkiss.dbeaver.ext.bigquery.model.BQMetaModel" driverClass="com.google.cloud.bigquery.jdbc.BigQueryDriver,com.simba.googlebigquery.jdbc42.Driver"/>
    </extension>

    <extension point="org.jkiss.dbeaver.dataSourceAuth">
        <authModel
                id="google_bigquery"
                label="Google Cloud Auth"
                description="BigQuery internal authentication"
                class="org.jkiss.dbeaver.ext.bigquery.auth.BQAuthModel"
                default="true">
            <replace model="native"/>
            <datasource id="bigquery"/>
        </authModel>
    </extension>

</plugin>
